{% import "html/macros/forms.twig" as forms %}
<div class="usa-card-group margin-top-3">
{% for l in legislation %}
<article    class="usa-card__container margin-bottom-2 grid-col-12">
    <header class="usa-card__header">
        <h2 class="usa-card__heading">
            <a class="usa-link" href="{{ uri('legislation.view', { legislation_id: l.id, committee_id: l.committee_id }) }}">
                {{ l.type }} {{ l.number }} {{ l.status ? l.status.name : '' }}
            </a>
        </h2>
    </header>
    <div class="usa-card__body">
        <p>{{ l.title }}</p>
        <div>
            {% for f in l.files -%}
            {{- forms.actionLink(f.url ?? uri('legislationFiles.download', { legislationFile_id: f.id}), f.filename, 'download') -}}
            {%- endfor %}
        </div>
    </div>
</article>
{% endfor %}
</div>
