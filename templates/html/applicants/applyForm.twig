{% extends "html/layouts/committee.twig" %}
{% import  "html/macros/forms.twig" as forms %}
{% block content %}
<section>
    <header>
        <h1>{{ _('applyToCommittee', 'messages')|format(committee.name) }}</h1>
    </header>

    {{ help|markdown_to_html }}

    <form           class="usa-form usa-form--large" method="post">
        <fieldset   class="usa-fieldset">
            <legend class="usa-legend usa-legend--large">{{ _('contactInfo') }}</legend>
            <table>
                <tr><th>{{ _('email') }} *</th><td>{{ USER.email ?? forms.actionLink(uri('profile.emails.add') ~ '?return_url=' ~ current_url(), _('email_add'), 'add') }}</td></tr>
                <tr><th>{{ _('address_home') }} *</th><td>{{ USER.getAddress('Home') ?? forms.actionLink(uri('profile.addresses.add') ~ '?type=Home&return_url=' ~ current_url(), _('address_add'), 'add') }}</td></tr>
            </table>
            {{ forms.actionLink(uri('profile.index'), _('profile_edit'), 'edit') }}
        </fieldset>
        {% if USER.email and USER.getAddress('Home') %}
        <fieldset   class="usa-fieldset">
            <legend class="usa-legend usa-legend--large">{{ _('referral') }}</legend>
            {{ forms.field_select('referredFrom',  'referredFrom',  _('referredFrom'),  post.referredFrom  ?? '', referral_options ) }}
            {{ forms.field_text  ('referredOther', 'referredOther', _('referredOther'), post.referredOther ?? '' ) }}
        </fieldset>

        <fieldset   class="usa-fieldset margin-bottom-3">
            <legend class="usa-legend usa-legend--large">{{ _('interest_label') }}</legend>
            {{ forms.field_textarea('interest', 'interest', _('interest'), post.interest ?? '' ) }}
        </fieldset>

        <fieldset   class="usa-fieldset margin-bottom-3">
            <legend class="usa-legend usa-legend--large">{{ _('qualifications_label') }}</legend>
            {{ forms.field_textarea('qualifications', 'qualifications', _('qualifications'), post.qualifications ?? '' ) }}
        </fieldset>

        <fieldset   class="usa-fieldset">
            {{ forms.button('submit', _('save'), 'save') }}
            {{ forms.actionLink(uri('committees.info', { committee_id: committee.id }), _('cancel'), 'cancel' ) }}
        </fieldset>
        {% endif %}
    </form>
</section>
{% endblock %}
